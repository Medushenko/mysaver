# MySaver Environment Configuration
# PostgreSQL (Production & Local Development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mysaver

# Redis (Caching & Celery Broker)
REDIS_URL=redis://localhost:6379/0

# rclone Remote Control
RCLONE_RC_ADDR=http://localhost:5572

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_admin_chat_id

# Cache Configuration
CACHE_TTL_SECONDS=3600
MAX_CACHE_SIZE_BYTES=1073741824
